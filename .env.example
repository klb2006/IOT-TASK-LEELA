# ========================================
# IoT Water Tank Monitoring System
# Environment Variables Configuration
# ========================================
# Copy this file to .env and fill in your actual values
# For detailed setup instructions, see FRONTEND_DEPLOYMENT.md and BACKEND_DEPLOYMENT.md

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Local Development
DATABASE_URL=postgresql://postgres:password@localhost:5432/water_tank_db

# For Render Deployment - Replace with your Render PostgreSQL values:
# DATABASE_URL=postgresql://user:password@dpg-xxxxx-a.oregon-postgres.render.com:5432/water_tank_db

# Individual Database Variables (Alternative to DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=water_tank_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSLMODE=disable

# For Render PostgreSQL (update after creating database):
# DB_HOST=dpg-xxxxx-a.oregon-postgres.render.com
# DB_PORT=5432
# DB_NAME=<database_name>
# DB_USER=<database_user>
# DB_PASSWORD=<database_password>
# DB_SSLMODE=require

# ========================================
# APPLICATION CONFIGURATION
# ========================================
# Backend Server Port
API_PORT=8000

# Backend API URL (used by frontend to make requests)
# Local Development
VITE_API_URL=http://localhost:8000

# Production (after backend deployment to Render):
# VITE_API_URL=https://iot-water-tank-backend.onrender.com

# Frontend URL (used by backend for CORS settings)
# Local Development
FRONTEND_URL=http://localhost:3000

# Production (after frontend deployment to Render):
# FRONTEND_URL=https://iot-water-tank-frontend.onrender.com

# ========================================
# SENSOR CONFIGURATION
# ========================================
# Sensor data collection interval (seconds)
SENSOR_UPDATE_INTERVAL=5

# ========================================
# OPTIONAL: THINGSPEAK INTEGRATION
# ========================================
# Only needed if using ThingSpeak for data logging
# THINGSPEAK_CHANNEL_ID=your_channel_id
# THINGSPEAK_API_KEY=your_api_key

# ========================================
# OPTIONAL: ML MODEL CONFIGURATION
# ========================================
# Path to trained ML model
MODEL_PATH=saved_models/best_model.h5

# ========================================
# SECURITY (Production Only)
# ========================================
# Set to False for production
DEBUG=True

# Secret key for JWT (generate a strong random string for production)
SECRET_KEY=your-secret-key-change-in-production

# ========================================
# DEPLOYMENT NOTES
# ========================================
# RENDER DEPLOYMENT:
# 1. Create PostgreSQL database on Render
# 2. Copy database credentials to DATABASE_URL or individual DB_* variables
# 3. Update VITE_API_URL after backend deployment
# 4. Update FRONTEND_URL after frontend deployment
# 5. Update CORS settings in backend/main.py with FRONTEND_URL

# LOCAL DEVELOPMENT:
# Make sure PostgreSQL is running locally
# Default values assume local setup; change as needed

# IMPORTANT SECURITY:
# - Never commit .env file to Git
# - Always use strong passwords for production
# - Use environment variables provided by Render for sensitive data
# - Rotate credentials periodically

