# ========================================
# Water Tank Monitoring System - Environment Variables
# ========================================
# Copy this file to .env and fill in your actual values

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=water_tank_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSLMODE=disable

# ========================================
# API CONFIGURATION
# ========================================
# Backend API URL (for local development)
VITE_API_URL=http://localhost:8000

# Frontend URL (used by backend for CORS)
FRONTEND_URL=http://localhost:5173

# ========================================
# ML MODEL CONFIGURATION
# ========================================
MODEL_PATH=saved_models/best_model.h5

# ========================================
# THINGSPEAK API (if using)
# ========================================
# THINGSPEAK_CHANNEL_ID=your_channel_id
# THINGSPEAK_API_KEY=your_api_key

# ========================================
# RENDER.COM DEPLOYMENT
# ========================================
# When deploying on Render, update these values:
# DB_HOST=your_database_host.render.com
# DB_PORT=5432
# VITE_API_URL=https://your-backend.render.com
# FRONTEND_URL=https://your-frontend.render.com
